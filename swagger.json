  "components": {
    "schemas": {
      "AccessToken": {
        "properties": {
          "access_token": {
            "type": "string",
            "title": "Access Token"
          }
        },
        "type": "object",
        "required": [
          "access_token"
        ],
        "title": "AccessToken",
        "description": "Access token for authenticated user."
      },
      "AverageBookingsPerUser": {
        "properties": {
          "average_bookings_per_user": {
            "type": "number",
            "title": "Average Bookings Per User"
          }
        },
        "type": "object",
        "required": [
          "average_bookings_per_user"
        ],
        "title": "AverageBookingsPerUser",
        "description": "The metric of the average number of bookings per user."
      },
      "AverageRegistrations": {
        "properties": {
          "average_registrations": {
            "type": "number",
            "title": "Average Registrations"
          }
        },
        "type": "object",
        "required": [
          "average_registrations"
        ],
        "title": "AverageRegistrations",
        "description": "The metric of the average number of bookings per event."
      },
      "Booking": {
        "properties": {
          "event_id": {
            "type": "integer",
            "title": "Event Id"
          },
          "user_email": {
            "type": "string",
            "title": "User Email"
          }
        },
        "type": "object",
        "required": [
          "event_id",
          "user_email"
        ],
        "title": "Booking",
        "description": "Booking model."
      },
      "EventBase": {
        "properties": {
          "title": {
            "type": "string",
            "maxLength": 80,
            "minLength": 3,
            "title": "Title"
          },
          "description": {
            "anyOf": [
              {
                "type": "string",
                "maxLength": 1000,
                "minLength": 3
              },
              {
                "type": "null"
              }
            ],
            "title": "Description"
          },
          "date": {
            "type": "string",
            "format": "date-time",
            "title": "Date"
          },
          "is_offline": {
            "type": "boolean",
            "title": "Is Offline"
          },
          "location": {
            "type": "string",
            "maxLength": 200,
            "minLength": 3,
            "title": "Location"
          },
          "max_participants": {
            "anyOf": [
              {
                "type": "integer",
                "exclusiveMinimum": 0
              },
              {
                "type": "null"
              }
            ],
            "title": "Max Participants"
          }
        },
        "type": "object",
        "required": [
